# Langflow connection settings
LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_FLOW_ID=your_flow_id_here
LANGFLOW_API_KEY=your_api_key_here

# Provider credentials passed to Langflow as X-LANGFLOW-GLOBAL-VAR-* headers.
# Set the one that matches the provider used by your flow.
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional request tuning
LANGFLOW_INPUT_TYPE=chat
LANGFLOW_OUTPUT_TYPE=chat

# Optional per-run component overrides. Must be valid JSON.
# Example:
# LANGFLOW_TWEAKS_JSON={"LanguageModelComponent-VRIa8":{"temperature":0.2}}

# Optional frontend ports
GRADIO_SERVER_PORT=7861
STREAMLIT_SERVER_PORT=8501
