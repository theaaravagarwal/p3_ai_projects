# Prof. Sage Homework Helper Bot Configuration

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# API Server Configuration (optional)
API_HOST=0.0.0.0
API_PORT=8000

# Deployment Environment
# Options: development, staging, production
ENVIRONMENT=development

# Model Configuration
# Available: gpt-5-nano (cheapest) or gpt-4o-mini
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_OUTPUT_TOKENS=64
OPENAI_MAX_HISTORY_MESSAGES=2
# GPT-5 models only accept the default temperature, so the code ignores custom values here.
OPENAI_TEMPERATURE=0.1
OPENAI_REASONING_EFFORT=minimal
OPENAI_REQUEST_TIMEOUT_SECONDS=45

# Legacy aliases still supported:
# MODEL_NAME=gpt-5-nano
# MAX_TOKENS=64
# TEMPERATURE=0.1

# Logging
LOG_LEVEL=INFO
